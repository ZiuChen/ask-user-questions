{
  "name": "ask-user-questions",
  "version": "0.1.0",
  "type": "module",
  "description": "An MCP tool that allows AI models to ask users questions via a local web interface.",
  "author": "",
  "license": "MIT",
  "bin": {
    "ask-user-questions": "./dist/bin.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && pnpm run copy:app && pnpm run postbuild",
    "copy:app": "mkdir -p dist/public && cp -rf ../app/dist/* ./dist/public/ 2>/dev/null || true",
    "postbuild": "printf '%s\\n' '#!/usr/bin/env node' \"$(cat dist/bin.mjs)\" > dist/bin.mjs && chmod +x dist/bin.mjs && printf '%s\\n' '#!/usr/bin/env node' \"$(cat dist/daemon.mjs)\" > dist/daemon.mjs && chmod +x dist/daemon.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.12.3",
    "node-notifier": "^10.0.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/node-notifier": "^8.0.5",
    "@types/ws": "^8.18.1",
    "tsdown": "0.21.0-beta.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "url": "https://github.com/ZiuChen/ask-user-questions"
  }
}
