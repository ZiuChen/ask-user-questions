{
  "name": "ask-user-questions-monorepo",
  "private": true,
  "type": "module",
  "description": "An MCP tool that allows AI models to ask users questions via a local web interface.",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter @ask-user-questions/app build && pnpm --filter ask-user-questions build",
    "build:app": "pnpm --filter @ask-user-questions/app build",
    "build:server": "pnpm --filter ask-user-questions build",
    "dev": "pnpm --filter @ask-user-questions/app dev",
    "dev:server": "pnpm --filter ask-user-questions dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
